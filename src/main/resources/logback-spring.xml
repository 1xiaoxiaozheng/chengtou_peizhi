<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- 定义日志文件的存储地址 -->
    <property name="LOG_HOME" value="C:/Users/19795/Desktop/log"/>
    <!-- 全量日志路径 -->
    <property name="ALL_LOG_HOME" value="D:/springbooot/Log/allLog"/>
    <!-- 错误日志路径 -->
    <property name="ERROR_LOG_HOME" value="D:/springbooot/Log/error"/>
    
    <!-- 控制台输出 -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{50} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <!-- 只输出INFO及以上级别的日志到控制台 -->
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>INFO</level>
        </filter>
    </appender>

    <!-- 文件输出 - 所有日志（每日滚动） -->
    <appender name="FILE_ALL" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <!-- 当前日志文件 -->
        <file>${ALL_LOG_HOME}/application.log</file>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{50} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <!-- 日志文件名格式：每日一个文件 -->
            <fileNamePattern>${ALL_LOG_HOME}/application.%d{yyyy-MM-dd}.log</fileNamePattern>
            <!-- 日志保留天数 -->
            <maxHistory>30</maxHistory>
            <!-- 每日滚动，不按大小分割 -->
            <totalSizeCap>10GB</totalSizeCap>
        </rollingPolicy>
    </appender>

    <!-- 文件输出 - 业务日志（按日还款计划相关） -->
    <appender name="FILE_DAILY_PAYMENT" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_HOME}/daily-payment.log</file>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{50} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_HOME}/daily-payment.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxHistory>30</maxHistory>
            <timeBasedFileNamingAndTriggeringPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedFNATP">
                <maxFileSize>50MB</maxFileSize>
            </timeBasedFileNamingAndTriggeringPolicy>
        </rollingPolicy>
    </appender>

    <!-- 文件输出 - 错误日志（每日滚动） -->
    <appender name="FILE_ERROR" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <!-- 当前日志文件 -->
        <file>${ERROR_LOG_HOME}/error.log</file>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{50} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <!-- 日志文件名格式：每日一个文件 -->
            <fileNamePattern>${ERROR_LOG_HOME}/error.%d{yyyy-MM-dd}.log</fileNamePattern>
            <!-- 日志保留天数 -->
            <maxHistory>30</maxHistory>
            <!-- 每日滚动，不按大小分割 -->
            <totalSizeCap>5GB</totalSizeCap>
        </rollingPolicy>
        <!-- 只记录ERROR级别的日志 -->
        <filter class="ch.qos.logback.classic.filter.LevelFilter">
            <level>ERROR</level>
            <onMatch>ACCEPT</onMatch>
            <onMismatch>DENY</onMismatch>
        </filter>
    </appender>

    <!-- MyBatis SQL日志 - 设置为WARN级别，只记录错误，不记录SQL详细结果 -->
    <!-- 如果需要查看SQL，可以临时改为DEBUG，但会输出大量日志 -->
    <logger name="com.SpringbootTZ.FACT.Mapper" level="WARN" additivity="false">
        <appender-ref ref="FILE_ALL"/>
        <!-- 不输出到控制台，减少刷屏 -->
    </logger>
    
    <!-- MyBatis框架日志 - 设置为WARN，减少框架内部日志 -->
    <logger name="org.apache.ibatis" level="WARN"/>
    <logger name="java.sql" level="WARN"/>
    <logger name="java.sql.Statement" level="WARN"/>
    <logger name="java.sql.ResultSet" level="WARN"/>
    <logger name="java.sql.Connection" level="WARN"/>
    <logger name="java.sql.PreparedStatement" level="WARN"/>

    <!-- 按日还款计划相关日志 -->
    <logger name="com.SpringbootTZ.FACT.Controller.DailyRepaymentPlanControl" level="INFO" additivity="false">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE_DAILY_PAYMENT"/>
        <appender-ref ref="FILE_ALL"/>
    </logger>
    
    <logger name="com.SpringbootTZ.FACT.Service.DailyPayment.DailyRepaymentPlanService" level="INFO" additivity="false">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE_DAILY_PAYMENT"/>
        <appender-ref ref="FILE_ALL"/>
    </logger>

    <!-- 根日志级别 -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE_ALL"/>
        <appender-ref ref="FILE_ERROR"/>
    </root>

</configuration>

